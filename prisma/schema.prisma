// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  nome      String
  login     String   @unique
  senha     String
  createdAt DateTime @default(now())

  examesCriados Exame[] @relation("UserExames")
}

model Paciente {
  id             String  @id @default(uuid())
  nome           String
  cpf            String  @unique
  email          String?
  telefone       String?
  dataNascimento String?
  nacionalidade  String?
  sexo           Sexo
  endereco       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exames Exame[]
}

model Exame {
  id           String      @id @default(uuid())
  numero       String      @unique
  tipo         TipoExame
  status       StatusExame @default(PENDENTE)
  dataCadastro DateTime    @default(now())

  // 🔗 Paciente
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
  pacienteId String

  // 🔗 Usuário
  user   User   @relation("UserExames", fields: [userId], references: [id])
  userId String

  // 🔗 Serviços (N:N)
  servicos ExameServico[]
}

model Servico {
  id     String  @id @default(uuid())
  nome   String
  status Boolean @default(true)

  exames ExameServico[]
}

model ExameServico {
  id String @id @default(uuid())

  exame   Exame  @relation(fields: [exameId], references: [id])
  exameId String

  servico   Servico @relation(fields: [servicoId], references: [id])
  servicoId String

  createdAt DateTime @default(now())
}

enum StatusExame {
  PENDENTE
  CONCLUIDO
}

enum Sexo {
  Masculino
  Feminino
}

enum TipoExame {
  ANATOMO
  COLPO
  IMUNO
  OUTROS
}
